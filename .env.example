APP_NAME=Laklak Nightclub Booking API
APP_ENV=local
SECRET_KEY=change-me
QR_HMAC_SECRET=change-me-to-a-long-random-string

# XAMPP MariaDB/MySQL default root user usually has no password.
PORT=8000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nightclub_booking
DB_USER=root
DB_PASSWORD=

# Firebase is wired in Phase 2. These stay empty for Phase 1.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
